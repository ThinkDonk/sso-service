# 服务监听配置
SSO_HOST=127.0.0.1
SSO_PORT=8000

# Issuer 对外可访问地址（无尾斜杠）
SSO_ISSUER_URL=http://localhost:8000

# sqlite 数据库文件路径
SSO_DB_PATH=./sso.db

# JWT 签名密钥（HS256），生产环境务必修改
SSO_JWT_SECRET=change-me-to-a-long-random-string

# 静态客户端注册（Outline 使用）
SSO_CLIENT_ID=outline
SSO_CLIENT_SECRET=change-me
# Outline 回调地址，多个用逗号分隔
SSO_REDIRECT_URIS=https://wiki.example.com/auth/oidc.callback

# 首次启动时创建的默认管理员账号
SSO_SEED_USERNAME=admin
SSO_SEED_PASSWORD=admin123
SSO_SEED_EMAIL=admin@example.com
SSO_SEED_NAME=管理员

# 无邮箱用户拼接域名（userid@此域名）
SSO_EMAIL_DOMAIN=local.sso.invalid

# access_token 有效期（秒）
SSO_ACCESS_TOKEN_EXPIRES=3600
# 授权码有效期（秒）
SSO_CODE_EXPIRES=600

# 管理后台会话签名密钥（生产环境务必修改）
SSO_SESSION_SECRET=change-me-to-a-long-random-string
# 会话有效期（秒），默认8小时
SSO_SESSION_MAX_AGE=28800
